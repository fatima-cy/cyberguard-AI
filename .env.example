# ============================================================
# CyberGuard AI Platform — Environment Variables Reference
# ============================================================
#
# USAGE:
#   cp .env.example .env
#   Edit .env with your local values
#
# SECURITY RULES:
#   - NEVER commit .env to git (it is in .gitignore)
#   - NEVER put real secrets in .env.example
#   - All production secrets live in Azure Key Vault
#   - App Service reads secrets via Managed Identity references
#
# MANAGED IDENTITY FIRST:
#   In Azure (App Service / AKS): services authenticate via System-Assigned
#   Managed Identity. Connection strings are NOT set in Azure environments.
#
#   Locally: run `az login` and DefaultAzureCredential uses your CLI session.
#   Connection strings below are for local emulators (Cosmos, Redis, Azurite)
#   and are ONLY needed if you are not using `az login`.
#
# @see Sprint 0 v1.1 §15 — Managed Identity Architecture
# @see Blueprint §7.3 — Authentication Architecture
# @see docs/architecture-decisions/ADR-002-azure-openai.md
# ============================================================


# ── APPLICATION ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_VERSION=0.1.0
LOG_LEVEL=debug

# Comma-separated allowed CORS origins (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ── AZURE MANAGED IDENTITY (primary — used in App Service) ───────────────────
# These are set automatically by Azure when Managed Identity is enabled.
# For local development: run `az login` — DefaultAzureCredential picks up your
# CLI session automatically. Leave these BLANK if using `az login`.
#
# Only set these if you cannot run `az login` (e.g. in some CI environments):
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=


# ── AZURE SERVICE ENDPOINTS (always required — not secrets) ──────────────────
# These are endpoint URLs, not credentials. Safe to set as App Service config.

# Azure Cosmos DB NoSQL — used in staging/prod via Managed Identity
COSMOS_ENDPOINT=https://cs-dev-cosmos.documents.azure.com:443/

# Azure Redis Cache — used in staging/prod via Entra token auth
REDIS_ENDPOINT=cs-dev-redis.redis.cache.windows.net:6380

# Azure Service Bus — used in staging/prod via Managed Identity
SERVICEBUS_NAMESPACE=cs-dev-bus.servicebus.windows.net

# Azure OpenAI — used in staging/prod via Managed Identity
OPENAI_ENDPOINT=https://cs-dev-openai.openai.azure.com/

# Azure AI Search — used in staging/prod via Managed Identity
AISEARCH_ENDPOINT=https://cs-dev-search.search.windows.net

# Azure AI Language (PII detection) — used in staging/prod via Managed Identity
AILANGUAGE_ENDPOINT=https://cs-dev-ailanguage.cognitiveservices.azure.com/

# Azure Blob Storage — used in staging/prod via Managed Identity
BLOB_ENDPOINT=https://csdevblob.blob.core.windows.net

# Azure Key Vault — required even in production (Managed Identity reads secrets from here)
KEYVAULT_URI=https://cs-dev-kv.vault.azure.net/

# Azure App Configuration (Feature Flags)
APP_CONFIG_ENDPOINT=https://cs-dev-appconfig.azconfig.io


# ── LOCAL EMULATOR FALLBACK CONNECTION STRINGS ───────────────────────────────
# These are ONLY used when Managed Identity is not available (local dev without
# `az login`, or CI test environments with emulators).
# DefaultAzureCredential falls back to these automatically.
# In staging/prod: NEVER set these — Managed Identity handles auth.

# Cosmos DB Emulator (docker-compose cosmos service)
# The emulator key below is the well-known public default key — not a secret
COSMOS_CONNECTION_STRING=AccountEndpoint=https://localhost:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMcZcLU/D5YB==;
COSMOS_DATABASE_NAME=cloudsecure_platform

# Redis (docker-compose redis service)
REDIS_CONNECTION_STRING=redis://localhost:6379

# Azure Blob Storage — Azurite emulator (docker-compose azurite service)
# The Azurite key below is the well-known public default key — not a secret
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://localhost:10000/devstoreaccount1;

# Azure Service Bus — use real dev Service Bus (no local emulator)
SERVICEBUS_CONNECTION_STRING=

# Azure OpenAI — use real dev OpenAI resource (no local emulator)
OPENAI_API_KEY=

# Azure AI Search — use real dev Search resource
AISEARCH_API_KEY=

# Azure AI Language — use real dev Language resource
AILANGUAGE_API_KEY=


# ── AZURE SERVICE BUS — TOPIC AND QUEUE NAMES ────────────────────────────────
SERVICEBUS_TOPIC_USER_EVENTS=user.events
SERVICEBUS_TOPIC_ORG_EVENTS=org.events
SERVICEBUS_TOPIC_SUBSCRIPTION_EVENTS=subscription.events
SERVICEBUS_TOPIC_AI_EVENTS=ai.events
SERVICEBUS_TOPIC_NOTIFICATION_EVENTS=notification.events

SERVICEBUS_QUEUE_POLICY_EXPORT=policy-export-queue
SERVICEBUS_QUEUE_REPORT=report-generation-queue
SERVICEBUS_QUEUE_WEBHOOK=webhook-processing-queue
SERVICEBUS_QUEUE_KNOWLEDGE=knowledge-ingestion-queue
SERVICEBUS_QUEUE_EMAIL=email-delivery-queue


# ── AZURE OPENAI — MODEL CONFIGURATION ───────────────────────────────────────
OPENAI_CHAT_DEPLOYMENT=gpt-4o
OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
OPENAI_CHAT_MAX_TOKENS=800


# ── AZURE AI SEARCH — INDEX NAMES ────────────────────────────────────────────
AISEARCH_INDEX_CYBERGUARD=cloudsecure-knowledge-cyberguard
AISEARCH_INDEX_ACADEMY=cloudsecure-knowledge-academy
AISEARCH_INDEX_SARAH=cloudsecure-knowledge-sarah
AISEARCH_INDEX_ECOCOLD=cloudsecure-knowledge-ecocold


# ── AZURE BLOB STORAGE — CONTAINER NAMES ─────────────────────────────────────
BLOB_CONTAINER_POLICIES=policies
BLOB_CONTAINER_REPORTS=reports
BLOB_CONTAINER_CERTIFICATES=certificates
BLOB_CONTAINER_KNOWLEDGE=knowledge-sources
BLOB_CONTAINER_AVATARS=avatars


# ── JWT AUTHENTICATION ────────────────────────────────────────────────────────
# RS256 asymmetric key pair — generate with:
#   openssl genrsa -out /tmp/jwt-private.pem 2048
#   openssl rsa -in /tmp/jwt-private.pem -pubout -out /tmp/jwt-public.pem
#   base64 -w 0 /tmp/jwt-private.pem   # paste value below
#   base64 -w 0 /tmp/jwt-public.pem    # paste value below
#   rm /tmp/jwt-private.pem /tmp/jwt-public.pem
#
# In staging/prod: keys live in Azure Key Vault as jwt-private-key and jwt-public-key
# App Service reads them via Key Vault references — never stored in App Service config

JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY_DAYS=30
JWT_EMAIL_VERIFY_EXPIRY=86400
JWT_PASSWORD_RESET_EXPIRY=3600


# ── SECURITY ──────────────────────────────────────────────────────────────────
# Use cost 10 locally (faster tests). Staging/prod uses 12.
BCRYPT_COST_FACTOR=10


# ── AZURE COMMUNICATION SERVICES ─────────────────────────────────────────────
ACS_CONNECTION_STRING=
ACS_SENDER_EMAIL=noreply@cyberguard.ai


# ── PAYMENT GATEWAYS ─────────────────────────────────────────────────────────
# Decision: OI-01 (Paystack primary, Flutterwave secondary)
# USE TEST KEYS ONLY in development and staging — never production keys locally

# Paystack (primary gateway — NGN payments)
PAYSTACK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_PAYSTACK_TEST_KEY
PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_PAYSTACK_TEST_KEY
PAYSTACK_WEBHOOK_SECRET=REPLACE_WITH_YOUR_PAYSTACK_WEBHOOK_SECRET

# Flutterwave (secondary gateway — multi-currency)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-REPLACE_WITH_YOUR_FLUTTERWAVE_TEST_KEY
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-REPLACE_WITH_YOUR_FLUTTERWAVE_TEST_KEY
FLUTTERWAVE_WEBHOOK_HASH=REPLACE_WITH_YOUR_FLUTTERWAVE_WEBHOOK_HASH


# ── AZURE ENTRA ID SSO ───────────────────────────────────────────────────────
# Enterprise SSO configuration (optional in Phase 1 — Enterprise tier only)
# Leave blank if not testing SSO locally
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=


# ── OBSERVABILITY ────────────────────────────────────────────────────────────
# Leave blank locally — App will start without App Insights (graceful no-op)
# In staging/prod: set via Key Vault reference in App Service config
APPLICATIONINSIGHTS_CONNECTION_STRING=


# ── BUSINESS CONFIGURATION ───────────────────────────────────────────────────
# NGN/USD exchange rate — used by cost-calculator.ts for NGN cost estimation.
# Updated periodically when rate changes significantly (not real-time FX).
FX_RATE_USD_TO_NGN=1600
FX_RATE_LAST_UPDATED=2026-06-01


# ── FRONTEND (Vite build-time variables — must be prefixed VITE_) ────────────
# These are injected at build time by Vite — they end up in the browser bundle.
# Never put secrets here — they are visible in the browser.
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_APP_ENV=development
VITE_PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_PAYSTACK_TEST_KEY
