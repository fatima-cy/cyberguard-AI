{
  "name": "@cyberguard/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --watch src -e ts --exec ts-node src/app.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test:unit": "jest --config jest.config.ts --testPathPattern=tests/unit",
    "test:integration": "jest --config jest.config.ts --testPathPattern=tests/integration/.*.test.ts",
    "test:tenant-isolation": "jest --config jest.config.ts --testPathPattern=tests/integration/tenant-isolation",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@azure/cosmos": "^4.1.0",
    "@azure/identity": "^4.2.1",
    "@azure/monitor-opentelemetry": "^1.6.0",
    "@cyberguard/shared": "*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^1.25.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.45.0",
    "uuid": "^14.0.1",
    "winston": "^3.13.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
